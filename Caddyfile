# Behind Tailscale Serve/Funnel: Tailscale terminates TLS with a valid ts.net
# cert and proxies here over plain HTTP. So Caddy listens on plain HTTP and just
# routes between the two SPAs and the API — no TLS, no DuckDNS, and no basic-auth
# popup (the password gate now lives in our own /login app).

:8088 {
	# CORS for the Hive Pocket app — its Capacitor WebView runs on the origin
	# https://localhost, so browsers preflight every API call. Answer the
	# preflight here (backends never see OPTIONS) and stamp Allow-Origin on
	# actual responses when that Origin is present. Requests without that
	# Origin header are untouched.
	@pocketPreflight {
		method OPTIONS
		header Origin https://localhost
	}
	handle @pocketPreflight {
		header Access-Control-Allow-Origin "https://localhost"
		header Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
		header Access-Control-Allow-Headers "Authorization, Content-Type, Accept, X-Hive-Workspace, X-Hive-Signature, X-Hive-Mode"
		header Access-Control-Max-Age "86400"
		respond "" 204
	}
	@pocketOrigin header Origin https://localhost
	header @pocketOrigin {
		Access-Control-Allow-Origin "https://localhost"
		Vary Origin
	}

	# API — JWT-protected at the application layer.
	handle /api/* {
		reverse_proxy api:8080
	}

	# Standalone login SPA (its own tiny app). handle_path strips the /login
	# prefix; the app is built with base "/login/" so its assets route back here.
	redir /login /login/
	handle_path /login/* {
		root * /srv-login
		try_files {path} /index.html
		file_server
	}

	# The Hive portal (Aether-Sight), over the hive-core docker network. Each
	# daemon is under /hive/api/<daemon> (prefix stripped); /hive* → the portal
	# (served at base /hive/). Host is rewritten so Vite's allowedHosts accepts it.
	handle_path /hive/api/spine/* {
		reverse_proxy spine:7000
	}
	handle_path /hive/api/wraith/* {
		reverse_proxy wraith-worker:5000
	}
	handle_path /hive/api/obsidian/* {
		reverse_proxy obsidian-mind:3000
	}
	handle_path /hive/api/chronos/* {
		reverse_proxy chronos:7000
	}
	# Bare /hive has no trailing slash, so Vite (base /hive/) 404s it — redirect
	# to /hive/ so the portal loads whether or not the user types the slash.
	redir /hive /hive/ 308
	handle /hive* {
		reverse_proxy spine-ui:5190 {
			header_up Host localhost
		}
	}

	# The Hive DEV environment lives on its own Funnel port (:8443), served by the
	# hive-dev stack's own gateway — not through this Caddy. See
	# The-Hive/deploy/gateway-dev.Caddyfile + Plan-Documents/ENVIRONMENTS.md.

	# Main control panel SPA. Reachable only with a valid JWT — enforced
	# client-side by a router guard (→ /login) and server-side by [Authorize].
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
